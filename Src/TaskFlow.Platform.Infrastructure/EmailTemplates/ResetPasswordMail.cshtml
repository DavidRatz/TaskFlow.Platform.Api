@model TaskFlow.Platform.Domain.Emails.Models.ResetPasswordMail

<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:600px; margin:0 auto; font-family:'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">
    <tr>
        <td align="center" style="padding:40px 20px;">
            <!-- Logo -->
            <table role="presentation" border="0" cellpadding="0" cellspacing="0">
                <tr>
                    <td style="text-align:center;">
                        <span style="font-size:32px; font-weight:700; color:#1f2937;">CarWash</span>
                        <span style="display:inline-block; background-color:#3b82f6; color:#ffffff; font-size:32px; font-weight:700; padding:4px 12px; border-radius:8px; margin-left:4px;">Flow</span>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    <tr>
        <td style="padding:0 20px;">
            <!-- Card container -->
            <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="border-radius:16px; overflow:hidden;">
                <tr>
                    <td style="padding:32px;">
                        <h1 style="margin:0 0 24px 0; font-size:24px; font-weight:600; color:#1f2937; text-align:center;">Réinitialisation de mot de passe</h1>

                        <p style="margin:0 0 16px 0; font-size:16px; line-height:1.6; color:#4b5563;">Bonjour @Model.FirstName,</p>

                        <p style="margin:0 0 24px 0; font-size:16px; line-height:1.6; color:#4b5563;">Vous avez demandé la réinitialisation de votre mot de passe. Cliquez sur le bouton ci-dessous pour créer un nouveau mot de passe.</p>

                        <!-- CTA Button -->
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin:0 0 24px 0;">
                            <tr>
                                <td align="center">
                                    <a href="@Model.ResetUrl" style="display:inline-block; background-color:#3b82f6; color:#ffffff; font-size:16px; font-weight:600; text-decoration:none; padding:14px 32px; border-radius:50px;">Réinitialiser mon mot de passe</a>
                                </td>
                            </tr>
                        </table>

                        <p style="margin:0 0 16px 0; font-size:14px; line-height:1.6; color:#6b7280; text-align:center;">Si vous n'avez pas demandé cette réinitialisation, vous pouvez ignorer cet e-mail en toute sécurité.</p>

                        <p style="margin:0; font-size:12px; line-height:1.6; color:#9ca3af; text-align:center;">Ce lien expire dans 24 heures.</p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    <tr>
        <td style="padding:24px 20px; text-align:center;">
            <p style="margin:0 0 4px 0; font-size:12px; color:#9ca3af;">Ce message est automatique, merci de ne pas répondre à cet e-mail.</p>
            <p style="margin:0; font-size:12px; color:#9ca3af;">© 2026 CarWashFlow. Tous droits réservés.</p>
        </td>
    </tr>
</table>
