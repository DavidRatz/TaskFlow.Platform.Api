@model TaskFlow.Platform.Domain.Emails.Models.OrganizationInvitationMail

<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:600px; margin:0 auto; font-family:'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">
    <tr>
        <td align="center" style="padding:40px 20px;">
            <table role="presentation" border="0" cellpadding="0" cellspacing="0">
                <tr>
                    <td style="text-align:center;">
                        <span style="font-size:32px; font-weight:700; color:#1f2937;">CarWash</span>
                        <span style="display:inline-block; background-color:#3b82f6; color:#ffffff; font-size:32px; font-weight:700; padding:4px 12px; border-radius:8px; margin-left:4px;">Flow</span>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    <tr>
        <td style="padding:0 20px;">
            <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="border-radius:16px; overflow:hidden;">
                <tr>
                    <td style="padding:32px;">
                        <h1 style="margin:0 0 24px 0; font-size:24px; font-weight:600; color:#1f2937; text-align:center;">Invitation a rejoindre @Model.OrganizationName</h1>

                        <p style="margin:0 0 16px 0; font-size:16px; line-height:1.6; color:#4b5563;">Bonjour @Model.InviteeFirstName,</p>

                        <p style="margin:0 0 24px 0; font-size:16px; line-height:1.6; color:#4b5563;">Vous avez ete invite a rejoindre l'organisation <strong>@Model.OrganizationName</strong> sur CarWashFlow.</p>

                        @if (Model.IsNewUser)
                        {
                            <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin:0 0 24px 0; background-color:#fef3c7; border-radius:12px;">
                                <tr>
                                    <td style="padding:20px;">
                                        <p style="margin:0 0 8px 0; font-size:14px; font-weight:600; color:#92400e;">Un compte a ete cree pour vous</p>
                                        <p style="margin:0 0 4px 0; font-size:14px; color:#92400e;">Email : @Model.InviteeEmail</p>
                                        <p style="margin:0 0 4px 0; font-size:14px; color:#92400e;">Mot de passe temporaire : <strong>@Model.TemporaryPassword</strong></p>
                                        <p style="margin:0; font-size:13px; color:#b45309;">Veuillez changer votre mot de passe apres votre premiere connexion.</p>
                                    </td>
                                </tr>
                            </table>
                        }
                        else
                        {
                            <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin:0 0 24px 0; background-color:#f3f4f6; border-radius:12px;">
                                <tr>
                                    <td style="padding:20px;">
                                        <p style="margin:0; font-size:14px; color:#6b7280;">Vous pouvez vous connecter avec votre compte existant pour acceder a l'organisation.</p>
                                    </td>
                                </tr>
                            </table>
                        }

                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin:0 0 24px 0;">
                            <tr>
                                <td align="center">
                                    <a href="#" style="display:inline-block; background-color:#3b82f6; color:#ffffff; font-size:16px; font-weight:600; text-decoration:none; padding:14px 32px; border-radius:50px;">Se Connecter</a>
                                </td>
                            </tr>
                        </table>

                        <p style="margin:0; font-size:14px; line-height:1.6; color:#6b7280; text-align:center;">Connectez-vous pour acceder a votre espace et gerer votre flotte de vehicules.</p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    <tr>
        <td style="padding:24px 20px; text-align:center;">
            <p style="margin:0 0 4px 0; font-size:12px; color:#9ca3af;">Ce message est automatique, merci de ne pas repondre a cet e-mail.</p>
            <p style="margin:0; font-size:12px; color:#9ca3af;">&copy; 2026 CarWashFlow. Tous droits reserves.</p>
        </td>
    </tr>
</table>
